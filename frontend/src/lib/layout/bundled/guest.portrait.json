{
  "version": 1,
  "mode": "guest",
  "orientation": "portrait",
  "theme": "editorial",
  "resolution": "1080p",
  "transition": "fade",
  "grid": { "cols": 8, "rows": 14, "gap": 14 },
  "tiles": [
    { "id": "photo", "type": "immich_slideshow", "x": 0, "y": 0, "w": 8, "h": 8, "props": { "interval": 10 } },
    { "id": "clock", "type": "clock", "x": 0, "y": 8, "w": 4, "h": 2 },
    { "id": "weather", "type": "weather", "x": 4, "y": 8, "w": 4, "h": 2 },
    { "id": "cal", "type": "calendar", "x": 0, "y": 10, "w": 8, "h": 2, "props": { "count": 3 } },
    { "id": "scenes", "type": "ambient_scenes", "x": 0, "y": 12, "w": 8, "h": 2 }
  ]
}
