{
  "version": 1,
  "mode": "shopping",
  "orientation": "portrait",
  "theme": "minimal-dark",
  "resolution": "1080p",
  "transition": "fade",
  "grid": { "cols": 8, "rows": 14, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 0, "y": 0, "w": 5, "h": 2, "props": { "format": "12h", "showDate": true } },
    { "id": "low", "type": "low_stock_alert", "x": 5, "y": 0, "w": 3, "h": 2 },
    { "id": "stores", "type": "shopping_by_store", "x": 0, "y": 2, "w": 8, "h": 10 },
    { "id": "inv", "type": "inventory_grid", "x": 0, "y": 12, "w": 8, "h": 2 }
  ]
}
