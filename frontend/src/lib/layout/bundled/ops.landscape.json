{
  "version": 1,
  "mode": "ops",
  "orientation": "landscape",
  "theme": "ops-cyberpunk",
  "resolution": "1080p",
  "transition": "flip",
  "grid": { "cols": 12, "rows": 8, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 0, "y": 0, "w": 3, "h": 2 },
    { "id": "alerts", "type": "alerts", "x": 3, "y": 0, "w": 6, "h": 2, "props": { "severity_min": "warn" } },
    { "id": "metrics", "type": "metrics_chart", "x": 9, "y": 0, "w": 3, "h": 2 },
    { "id": "svc", "type": "service_status", "x": 0, "y": 2, "w": 3, "h": 3 },
    { "id": "hosts", "type": "host_health", "x": 3, "y": 2, "w": 3, "h": 3 },
    { "id": "logs", "type": "log_tail", "x": 6, "y": 2, "w": 6, "h": 3, "props": { "lines": 14 } },
    { "id": "cams", "type": "frigate_camera", "x": 0, "y": 5, "w": 6, "h": 3, "props": { "camera": "driveway" } },
    { "id": "board", "type": "project_board", "x": 6, "y": 5, "w": 6, "h": 3 }
  ]
}
