{
  "version": 1,
  "mode": "work",
  "orientation": "landscape",
  "theme": "ops-cyberpunk",
  "resolution": "1080p",
  "transition": "flip",
  "grid": { "cols": 12, "rows": 8, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 0, "y": 0, "w": 3, "h": 2, "props": { "format": "24h" } },
    { "id": "cal", "type": "calendar", "x": 3, "y": 0, "w": 4, "h": 2 },
    { "id": "meet", "type": "meeting_countdown", "x": 7, "y": 0, "w": 3, "h": 2 },
    { "id": "pomo", "type": "pomodoro", "x": 10, "y": 0, "w": 2, "h": 2 },
    { "id": "board", "type": "project_board", "x": 0, "y": 2, "w": 8, "h": 3 },
    { "id": "prs", "type": "pr_list", "x": 8, "y": 2, "w": 4, "h": 3 },
    { "id": "deploy", "type": "deploy_pipeline", "x": 0, "y": 5, "w": 3, "h": 3 },
    { "id": "msgs", "type": "messages", "x": 3, "y": 5, "w": 3, "h": 3 },
    { "id": "health", "type": "host_health", "x": 6, "y": 5, "w": 3, "h": 3 },
    { "id": "metrics", "type": "metrics_chart", "x": 9, "y": 5, "w": 3, "h": 3 }
  ]
}
