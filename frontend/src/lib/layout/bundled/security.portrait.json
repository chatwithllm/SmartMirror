{
  "version": 1,
  "mode": "security",
  "orientation": "portrait",
  "theme": "security",
  "resolution": "1080p",
  "transition": "flip",
  "grid": { "cols": 8, "rows": 14, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 0, "y": 0, "w": 4, "h": 2, "props": { "format": "24h" } },
    { "id": "alarm", "type": "alarm_panel", "x": 4, "y": 0, "w": 4, "h": 2 },
    { "id": "cam-porch",     "type": "frigate_camera", "x": 0, "y": 2, "w": 8, "h": 3, "props": { "entity_id": "camera.porch" } },
    { "id": "cam-backyard",  "type": "frigate_camera", "x": 0, "y": 5, "w": 4, "h": 3, "props": { "entity_id": "camera.backyard" } },
    { "id": "cam-garage-out","type": "frigate_camera", "x": 4, "y": 5, "w": 4, "h": 3, "props": { "entity_id": "camera.garage_outside_camera_main" } },
    { "id": "cam-garage-in", "type": "frigate_camera", "x": 0, "y": 8, "w": 4, "h": 2, "props": { "entity_id": "camera.garage_inside_camera_fluent" } },
    { "id": "cam-living",    "type": "frigate_camera", "x": 4, "y": 8, "w": 4, "h": 2, "props": { "entity_id": "camera.living_room" } },
    { "id": "events", "type": "event_timeline", "x": 0, "y": 10, "w": 8, "h": 2 },
    { "id": "sensors", "type": "sensor_grid", "x": 0, "y": 12, "w": 5, "h": 1 },
    { "id": "quick", "type": "quick_actions", "x": 5, "y": 12, "w": 3, "h": 1 },
    { "id": "alerts", "type": "alerts", "x": 0, "y": 13, "w": 8, "h": 1, "props": { "severity_min": "warn" } }
  ]
}
