{
  "version": 1,
  "mode": "magic-mirror",
  "orientation": "portrait",
  "theme": "magic-mirror",
  "resolution": "1080p",
  "transition": "fade",
  "grid": { "cols": 8, "rows": 12, "gap": 8 },
  "tiles": [
    { "id": "header", "type": "editorial_header", "x": 0, "y": 0, "w": 8, "h": 4,
      "props": {
        "title": "The Mirror Daily",
        "weatherEntity": "weather.4340",
        "units": "imperial",
        "kpis": [
          { "entityId": "sensor.claude_usage_nik_endhuk_max_session_usage",       "label": "Session",       "suffix": "%", "bucketize": true },
          { "entityId": "sensor.claude_usage_nik_endhuk_max_session_reset_time",  "label": "Session Reset", "valueFormat": "relative" },
          { "entityId": "sensor.claude_usage_nik_endhuk_max_week_usage",          "label": "Week",          "suffix": "%", "bucketize": true },
          { "entityId": "sensor.claude_usage_nik_endhuk_max_week_usage_pace",     "label": "Week Pace",     "valueFormat": "percent_pace" },
          { "entityId": "sensor.claude_usage_nik_endhuk_max_weekly_reset_time",   "label": "Weekly Reset",  "valueFormat": "relative" }
        ]
      }
    },

    { "id": "section-2", "type": "section_host", "x": 0, "y": 4, "w": 8, "h": 4,
      "props": {
        "sectionId": "section-2",
        "channelConfig": {
          "pool": ["kanban_active", "calendar_today", "immich_photo", "news_tech", "calendar_tomorrow", "calendar_next"],
          "phaseDefaults": {
            "pratah": "kanban_active",
            "madhyahna": "kanban_active",
            "sandhya": "kanban_active",
            "ratri": "kanban_active"
          }
        }
      }
    },
    { "id": "section-3", "type": "section_host", "x": 0, "y": 8, "w": 8, "h": 4,
      "props": {
        "sectionId": "section-3",
        "channelConfig": {
          "pool": ["news_tech", "grocery", "calendar_today", "calendar_tomorrow"],
          "phaseDefaults": {
            "pratah": "news_tech",
            "madhyahna": "grocery",
            "sandhya": "grocery",
            "ratri": "grocery"
          }
        }
      }
    }
  ]
}
