{
  "version": 1,
  "mode": "relax",
  "orientation": "portrait",
  "theme": "minimal-dark",
  "resolution": "1080p",
  "transition": "flip",
  "grid": { "cols": 8, "rows": 14, "gap": 14 },
  "tiles": [
    { "id": "plex", "type": "plex_player", "x": 0, "y": 0, "w": 8, "h": 6, "audio": true, "props": { "autoplay": true, "mute": false, "ratingKey": "", "title": "Plex" } },
    { "id": "now", "type": "plex_now_playing", "x": 0, "y": 6, "w": 8, "h": 2 },
    { "id": "recent", "type": "plex_recent", "x": 0, "y": 8, "w": 8, "h": 3, "props": { "limit": 6 } },
    { "id": "clock", "type": "clock", "x": 0, "y": 11, "w": 4, "h": 3, "props": { "format": "24h", "showDate": true } },
    { "id": "weather", "type": "weather", "x": 4, "y": 11, "w": 4, "h": 3, "props": { "units": "metric", "days": 3 } }
  ]
}
