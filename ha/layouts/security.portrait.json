{
  "version": 1,
  "mode": "security",
  "orientation": "portrait",
  "theme": "security",
  "resolution": "1080p",
  "transition": "flip",
  "grid": { "cols": 8, "rows": 14, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 0, "y": 0, "w": 4, "h": 2, "props": { "format": "24h" } },
    { "id": "alarm", "type": "alarm_panel", "x": 4, "y": 0, "w": 4, "h": 2 },
    { "id": "cam-drive", "type": "frigate_camera", "x": 0, "y": 2, "w": 4, "h": 3, "props": { "camera": "driveway" } },
    { "id": "cam-back", "type": "frigate_camera", "x": 4, "y": 2, "w": 4, "h": 3, "props": { "camera": "backyard" } },
    { "id": "cam-porch", "type": "frigate_camera", "x": 0, "y": 5, "w": 4, "h": 3, "props": { "camera": "porch" } },
    { "id": "cam-garage", "type": "frigate_camera", "x": 4, "y": 5, "w": 4, "h": 3, "props": { "camera": "garage" } },
    { "id": "events", "type": "event_timeline", "x": 0, "y": 8, "w": 8, "h": 3 },
    { "id": "sensors", "type": "sensor_grid", "x": 0, "y": 11, "w": 5, "h": 2 },
    { "id": "quick", "type": "quick_actions", "x": 5, "y": 11, "w": 3, "h": 2 },
    { "id": "alerts", "type": "alerts", "x": 0, "y": 13, "w": 8, "h": 1, "props": { "severity_min": "warn" } }
  ]
}
