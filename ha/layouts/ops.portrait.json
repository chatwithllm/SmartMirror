{
  "version": 1,
  "mode": "ops",
  "orientation": "portrait",
  "theme": "ops-cyberpunk",
  "resolution": "1080p",
  "transition": "flip",
  "grid": { "cols": 8, "rows": 14, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 0, "y": 0, "w": 4, "h": 2, "props": { "format": "24h", "showSeconds": true, "showDate": true } },
    { "id": "weather", "type": "weather", "x": 4, "y": 0, "w": 4, "h": 2, "props": { "units": "metric", "days": 3 } },
    { "id": "alerts", "type": "alerts", "x": 0, "y": 2, "w": 8, "h": 2, "props": { "severity_min": "warn" } },
    { "id": "svc", "type": "service_status", "x": 0, "y": 4, "w": 4, "h": 3 },
    { "id": "hosts", "type": "host_health", "x": 4, "y": 4, "w": 4, "h": 3 },
    { "id": "metrics", "type": "metrics_chart", "x": 0, "y": 7, "w": 4, "h": 2, "props": { "title": "System" } },
    { "id": "cal", "type": "calendar", "x": 4, "y": 7, "w": 4, "h": 2, "props": { "count": 4 } },
    { "id": "news", "type": "news_briefing", "x": 0, "y": 9, "w": 4, "h": 2, "props": { "count": 5 } },
    { "id": "logs", "type": "log_tail", "x": 4, "y": 9, "w": 4, "h": 2, "props": { "source": "ha", "lines": 10 } },
    { "id": "iframe", "type": "iframe", "x": 0, "y": 11, "w": 8, "h": 3, "props": { "url": "" } }
  ]
}
