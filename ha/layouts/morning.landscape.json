{
  "version": 1,
  "mode": "morning",
  "orientation": "landscape",
  "theme": "minimal-dark",
  "resolution": "1080p",
  "transition": "flip",
  "grid": { "cols": 12, "rows": 8, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 0, "y": 0, "w": 4, "h": 3 },
    { "id": "weather", "type": "weather", "x": 4, "y": 0, "w": 5, "h": 3, "props": { "days": 5 } },
    { "id": "coffee", "type": "coffee_timer", "x": 9, "y": 0, "w": 3, "h": 3 },
    { "id": "cal", "type": "calendar", "x": 0, "y": 3, "w": 6, "h": 3 },
    { "id": "commute", "type": "commute", "x": 6, "y": 3, "w": 3, "h": 3 },
    { "id": "routine", "type": "routine_checklist", "x": 9, "y": 3, "w": 3, "h": 3 },
    { "id": "news", "type": "news_briefing", "x": 0, "y": 6, "w": 6, "h": 2 },
    { "id": "podcast", "type": "podcast", "x": 6, "y": 6, "w": 6, "h": 2, "audio": true }
  ]
}
