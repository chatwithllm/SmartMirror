{
  "version": 1,
  "mode": "night",
  "orientation": "landscape",
  "theme": "minimal-dark",
  "resolution": "1080p",
  "transition": "fade",
  "grid": { "cols": 12, "rows": 8, "gap": 14 },
  "tiles": [
    { "id": "clock", "type": "clock", "x": 3, "y": 1, "w": 6, "h": 4, "props": { "showSeconds": false, "showDate": true } },
    { "id": "weather", "type": "weather", "x": 0, "y": 5, "w": 6, "h": 3, "props": { "days": 3 } },
    { "id": "alerts", "type": "alerts", "x": 6, "y": 5, "w": 6, "h": 3, "props": { "severity_min": "critical" } }
  ]
}
